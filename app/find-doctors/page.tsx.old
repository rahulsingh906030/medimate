"use client"

import { useState, useEffect } from "react"
import { useSearchParams } from 'next/navigation'
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card'
import { Button } from '@/components/ui/button'
import { Loader2, MapPin, Search, Phone, Star, Navigation, AlertTriangle, RefreshCw } from 'lucide-react'
import { Header } from '@/components/header'
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select'
import { calculateDistance, formatDistance } from '@/lib/utils'
import { getUserLocation, type Location } from '@/lib/geolocation'
import type { DoctorType } from '@/types/doctor' // Assume Doctor type exported

interface Doctor {
  name: string
  specialty: string
  rating: number
  experience: string
  hospital: string
  distance: string
  phone: string
  address: string
  lat: number
  lng: number
  place_id?: string
}

const SPECIALTIES = [
  'General Physician',
  'Cardiologist',
  'Neurologist',
  'Dermatologist',
  'Orthopedic',
  'Pediatrician',
  'Psychiatrist',
  'ENT Specialist',
  'Gynecologist',
  'Ophthalmologist',
  'General',
  'Dentist',
  'Gastroenterologist'
]

export default function FindDoctorsPage() {
  const searchParams = useSearchParams()
  const [location, setLocation] = useState<Location | null>(null)
  const [locationStatus, setLocationStatus] = useState<'loading' | 'error' | 'ready'>('loading')
  const [specialty, setSpecialty] = useState(searchParams.get('specialty') || '')
  const [doctors, setDoctors] = useState<Doctor[]>([])
  const [searchLoading, setSearchLoading] = useState(false)
  const [apiError, setApiError] = useState('')
  const [refreshKey, setRefreshKey] = useState(0)

  // Get precise user location using lib
  useEffect(() => {
    let mounted = true

    const fetchLocation = async () => {
      try {
        setLocationStatus('loading')
        const userLoc = await getUserLocation()
        if (mounted) {
          setLocation(userLoc)
          setLocationStatus('ready')
        }
      } catch (err) {
        console.error('Location error:', err)
        if (mounted) {
          setLocationStatus('error')
          setApiError('Location access denied. Using Delhi fallback (enable GPS for exact location)')
        }
      }
    }

    fetchLocation()

    return () => {
      mounted = false
    }
  }, [refreshKey])

  // Auto-search if specialty from symptom checker
  useEffect(() => {
if (locationStatus === 'ready' && location && specialty) {
      handleSearch()
    }
  }, [locationStatus, specialty, location?.lat, location?.lng])

  const handleSearch = async () => {
    if (!location) return

    setSearchLoading(true)
    setApiError('')

    const lat = location.lat
    const lng = location.lng
    const spec = specialty || 'General Physician'

    try {
const response = await fetch(`/api/doctors?lat=${lat}&lng=${lng}&specialty=${encodeURIComponent(spec)}`)
      const data = await response.json()

      if (data.error) {
        throw new Error(data.error)
      }

      const doctorsWithDistance = data.doctors.map((doctor: Doctor) => ({
        ...doctor,
        distance: formatDistance(calculateDistance(lat, lng, doctor.lat, doctor.lng))
      } as Doctor))

      setDoctors(doctorsWithDistance)
    } catch (err: any) {
      setApiError(err.message)
    } finally {
      setSearchLoading(false)
    }
  }

  const refreshLocation = () => {
    setRefreshKey((prev) => prev + 1)
    setDoctors([])
    setApiError('')
  }

  const openInMaps = (address: string, lat?: number, lng?: number) => {
const query = lat && lng ? `${lat},${lng}` : encodeURIComponent(address)
    window.open(`https://www.google.com/maps/search/?api=1&query=${query}`, '_blank')
  }

  const mapUrl = location 
    ? `https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d14028.514!2d${location.lng}!3d${location.lat}!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0:0x0!2z${location.lat.toFixed(4)}!5e0!3m2!1sen!2sin!4v1724221651271`
    : `https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d14028.514!2d77.3910!3d28.5355!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x390ce2c59d2b7a6d:0x8b8e2e7e3e7e3e7e!2sDelhi!5e0!3m2!1sen!2sin!4v1724221651271`

  return (
    <div className="min-h-screen bg-background">
      <Header />

      <main className="container mx-auto px-4 py-8">
        <div className="max-w-6xl mx-auto">
          <div className="mb-8">
Find Nearby Doctors & Hospitals
            <p className="text-muted-foreground">Precise GPS location + real-time nearby doctors</p>
          </div>

          {/* Location Status */}
          <Card className="p-6 mb-8">
            <CardHeader>
              <CardTitle className="flex items-center gap-2 justify-between">
                📍 Current Location
locationStatus !== 'loading' && (
                  <Button variant="ghost" size="sm" onClick={refreshLocation}>
                    <RefreshCw className="h-4 w-4 mr-1" />
                    Refresh GPS
                  </Button>
                )
              </CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              {locationStatus === 'loading' && (
                <div className="flex items-center gap-2 p-4 bg-muted rounded-lg">
                  <Loader2 className="h-5 w-5 animate-spin" />
                  <span>Getting exact GPS coordinates + address...</span>
                </div>
              )}

locationStatus === 'ready' && location && (
                <div className="p-4 bg-gradient-to-r from-primary/10 to-primary/20 rounded-lg border">
                  <div className="font-semibold">{location.address}</div>
                  <div className="text-sm text-muted-foreground">
                    {location.lat.toFixed(4)}, {location.lng.toFixed(4)}
                  </div>
                </div>
              )}

              {locationStatus === 'error' && (
                <div className="p-4 bg-destructive/10 border-destructive rounded-lg">
                  <div className="flex items-start gap-2">
                    <AlertTriangle className="h-5 w-5 mt-0.5 flex-shrink-0" />
                    <div>
                      <div className="font-medium">Using Delhi fallback location</div>
                      <div className="text-sm">Enable browser location permissions for precise results</div>
                    </div>
                  </div>
                </div>
              )}
            </CardContent>
          </Card>

          {/* Search Form */}
          <Card className="p-6 mb-6">
            <div className="grid md:grid-cols-3 gap-4">
              <div>
                <label className="block text-sm font-medium mb-2">Specialty</label>
                <Select value={specialty} onValueChange={setSpecialty}>
                  <SelectTrigger>
                    <SelectValue placeholder="Choose specialty" />
                  </SelectTrigger>
                  <SelectContent>
                    {SPECIALTIES.map((spec) => (
                      <SelectItem key={spec} value={spec}>
                        {spec}
                      </SelectItem>
                    ))}
                  </SelectContent>
                </Select>
              </div>
              <div className="md:col-span-2 flex items-end gap-2">
                <Button 
                  onClick={handleSearch} 
                  disabled={searchLoading || locationStatus !== 'ready' || !location}
                  className="flex-1"
                >
                  {searchLoading ? (
                    <>
                      <Loader2 className="mr-2 h-4 w-4 animate-spin" />
                      Searching...
                    </>
                  ) : (
                    <>
                      <Search className="mr-2 h-4 w-4" />
                      Find Doctors ({locationStatus === 'ready' ? '<20km' : 'Loading location...'})
                    </>
                  )}
                </Button>
              </div>
            </div>
          </Card>

{apiError && (
            <Card className="p-4 mb-6 border-destructive/50 bg-destructive/10">
              <div className="flex items-center gap-2 text-destructive">
                <AlertTriangle className="h-5 w-5 flex-shrink-0" />
                {apiError}
              </div>
            </Card>
          )}

          {/* Doctors Results */}
          {searchLoading ? (
            <Card className="p-12 text-center">
              <Loader2 className="h-8 w-8 animate-spin mx-auto mb-4" />
              <p>Finding real doctors near {location?.address?.split(',')[0] || 'you'}...</p>
            </Card>
doctors.length === 0 && locationStatus === 'ready' ? (
            <Card className="p-12 text-center text-muted-foreground border-2 border-dashed border-muted">
              <MapPin className="h-12 w-12 mx-auto mb-4 opacity-50" />
              <h3 className="text-lg font-semibold mb-2">No doctors found</h3>
              <p>Try selecting a different specialty or refresh location</p>
            </Card>
          ) : (
            <div className="space-y-4">
              {doctors.map((doctor, index) => (
                <Card key={doctor.place_id || index} className="hover:shadow-xl transition-all">
                  <CardContent className="p-6">
                    <div className="flex flex-col lg:flex-row lg:gap-6 lg:items-start">
                      <div className="flex-1 mb-4 lg:mb-0">
                        <div className="flex items-start justify-between mb-3">
                          <CardTitle className="text-xl">{doctor.name}</CardTitle>
doctor.rating && doctor.rating > 0 && (
                            <div className="bg-accent px-2 py-1 rounded-full text-sm flex items-center gap-1">
                              <Star className="h-4 w-4 fill-current" />
                              {doctor.rating.toFixed(1)}
                            </div>
                          )}
                        </div>
                        <p className="text-lg font-medium text-muted-foreground mb-2">{doctor.hospital}</p>
                        <div className="space-y-2 text-sm">
                          <p className="flex items-center gap-2">
                            <MapPin className="h-4 w-4 flex-shrink-0" />
                            {doctor.address}
                            <span className="ml-auto font-bold text-primary text-base">{doctor.distance}</span>
                          </p>
                          {doctor.phone !== 'N/A' && (
                            <p className="flex items-center gap-2">
                              <Phone className="h-4 w-4 flex-shrink-0" />
                              {doctor.phone}
                            </p>
                          )}
                        </div>
                      </div>
                      <div className="flex flex-col sm:flex-row gap-3 min-w-fit">
                        {doctor.phone !== 'N/A' && (
                          <Button variant="outline" className="w-full sm:w-auto" asChild>
                            <a href={`tel:${doctor.phone}`}>
                              Call Doctor
                            </a>
                          </Button>
                        )}
                        <Button 
                          onClick={() => openInMaps(doctor.address, doctor.lat, doctor.lng)}
                          className="w-full sm:w-auto"
                        >
                          <Navigation className="h-4 w-4 mr-1" />
                          Directions
                        </Button>
                      </div>
                    </div>
                  </CardContent>
                </Card>
              ))}
            </div>
          )}

          {/* Dynamic Map centered on user location */}
          <Card className="mt-8">
            <CardHeader>
              <CardTitle>Your Area</CardTitle>
              <CardDescription>Map centered on your current location</CardDescription>
            </CardHeader>
            <CardContent>
              <iframe
                src={mapUrl}
                width="100%"
                height="400"
                style={{border:0}}
                loading="fast"
                allowFullScreen
                referrerPolicy="no-referrer-when-downgrade"
              />
            </CardContent>
          </Card>
        </div>
      </main>
    </div>
  )
}

